{
    "name": "davitec/dv-education-registration",
    "type": "typo3-cms-extension",
    "description": "Online registration for education courses. Participant sign-up with PDF confirmation, email notifications, and inquiry forms.",
    "license": "GPL-2.0-or-later",
    "authors": [{"name": "Davitec GmbH, +Pluswerk Standort Dresden", "email": "info@davitec.de"}],
    "require": {
        "php": "^8.2",
        "typo3/cms-core": "^12.4 || ^13.4",
        "typo3/cms-extbase": "^12.4 || ^13.4",
        "typo3/cms-fluid": "^12.4 || ^13.4",
        "typo3/cms-frontend": "^12.4 || ^13.4",
        "davitec/dv-education-courses": "^1.0 || @dev"
    },
    "require-dev": {
        "typo3/testing-framework": "^8.0 || ^9.0"
    },
    "autoload": {
        "psr-4": {"Davitec\\DvEducationRegistration\\": "Classes/"}
    },
    "extra": {
        "typo3/cms": {"extension-key": "dv_education_registration"}
    }
}
